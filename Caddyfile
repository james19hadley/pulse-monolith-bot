{$WEBHOOK_DOMAIN:localhost} {
    # 1. Allow multiple admin IPs explicitly to hit the dashboard /admin routes.
    # Put your IP addresses here. You can add as many as needed separated by a space.
    @adminAuth {
        path /admin/*
        remote_ip 127.0.0.1 192.168.1.1 10.0.0.1 7.7.7.7
    }

    # 2. Block everyone else from /admin/*
    @adminBlock {
        path /admin/*
        not remote_ip 127.0.0.1 192.168.1.1 10.0.0.1 7.7.7.7
    }
    
    respond @adminBlock "403 Forbidden - Unauthorized IP" 403

    reverse_proxy bot:8080
}
